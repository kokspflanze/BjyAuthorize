{
    "name":         "kokspflanze/bjy-authorize",
    "description":  "Laminas\\Acl based firewall system for Mezzio dispatch protection",
    "type":         "library",
    "license":      "BSD-3-Clause",
    "homepage":     "https://github.com/kokspflanze/BjyAuthorize",
    "keywords": [
        "mezzio",
        "acl",
        "authorization"
    ],
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "laminas/laminas-permissions-acl": "^2.18",
        "laminas/laminas-servicemanager": "^3.24 || ^4.12",
        "mezzio/mezzio-authentication": "^1.13",
        "mezzio/mezzio-authorization": "^1.11",
        "mezzio/mezzio-router": "^3.9 || ^4.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5.9",
        "doctrine/persistence": "^1.3.8 || ^2.2.2"
    },
    "autoload": {
        "psr-4": {
            "BjyAuthorize\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "laminas": {
            "config-provider": "BjyAuthorize\\ConfigProvider"
        }
    },
    "scripts": {
        "check": [
            "@cs-check",
            "@test"
        ],
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "test": "phpunit --colors=always --configuration phpunit.xml.dist"
    }
}
